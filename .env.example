# JID del único remitente aceptado por Marcus (opcional en self-chat mode).
# Formato: <id>@s.whatsapp.net (clásico) o <id>@lid (formato nuevo con privacidad).
# Si lo dejás vacío, Marcus detecta al conectar los JIDs propios (id/lid/phoneNumber)
# y acepta self-chat con cualquiera de ellos.
OWNER_WHATSAPP_JID=

# API key de Anthropic (se usa a partir del spec 002).
ANTHROPIC_API_KEY=

# Modelo de Claude por default.
CLAUDE_MODEL=claude-sonnet-4-6

# Conexión Prisma (se usa a partir del spec 002).
DATABASE_URL="file:./marcus.db"
