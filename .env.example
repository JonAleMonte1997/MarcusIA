# JID del único remitente aceptado por Marcus.
# Formato: <numero_sin_plus>@lid (ej: 5491122334455@lid)
OWNER_WHATSAPP_JID=@lid

# API key de Anthropic (se usa a partir del spec 002).
ANTHROPIC_API_KEY=

# Modelo de Claude por default.
CLAUDE_MODEL=claude-sonnet-4-6

# Conexión Prisma (se usa a partir del spec 002).
DATABASE_URL="file:./marcus.db"

# Google Calendar OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth2callback
GOOGLE_CALENDAR_ID=primary

# Sesión
SESSION_TIMEOUT_HOURS=6

# Memoria
MEMORY_MAX_ENTRIES=50

# Logging
LOG_LEVEL=info
